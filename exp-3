import numpy as np
house_data = np.array([
    [3, 1200, 250000],
    [5, 2000, 450000],
    [4, 1800, 350000],
    [6, 2500, 550000],
    [5, 2200, 500000]
])
houses = house_data[house_data[:, 0] > 4]
average_price = np.mean(houses[:, 2])
print("Average Sale Price of Houses with More Than 4 Bedrooms:", average_price)
